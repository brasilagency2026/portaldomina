PAYPAL_PREMIUM_PLAN_ID=your-paypal-plan-id
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
NEXT_PUBLIC_PAYPAL_PREMIUM_PLAN_ID=your-paypal-plan-id

# Vite aliases (fallback compatibility)
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
VITE_PAYPAL_PREMIUM_PLAN_ID=your-paypal-plan-id

# App Settings
VITE_APP_TITLE=BDSMBRAZIL